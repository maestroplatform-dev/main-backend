/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model reviews {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  student_id String    @db.Uuid
  teacher_id String    @db.Uuid
  booking_id String?   @db.Uuid
  rating     Int
  comment    String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  students   students  @relation(fields: [student_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  teachers   teachers  @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([teacher_id], map: "idx_reviews_teacher")
  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model students {
  id                  String               @id @db.Uuid
  created_at          DateTime?            @default(now()) @db.Timestamptz(6)
  name                String?
  date_of_birth       DateTime?            @db.Date
  email_verified      Boolean              @default(false)
  gender              String?
  guardian_name       String?
  guardian_phone      String?
  onboarding_status   String               @default("email_entry")
  profile_picture_url String?
  signup_method       String               @default("email")
  updated_at          DateTime?            @default(now()) @db.Timestamptz(6)
  bookings            bookings[]
  purchased_packages  purchased_packages[]
  reviews             reviews[]
  profiles            profiles             @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model teacher_availability {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacher_id   String   @db.Uuid
  day_of_week  Int
  start_time   String
  end_time     String
  is_recurring Boolean? @default(true)
  teachers     teachers @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model teachers {
  id                           String                 @id @db.Uuid
  bio                          String?
  experience_years             Int?
  verified                     Boolean?               @default(false)
  created_at                   DateTime?              @default(now()) @db.Timestamptz(6)
  name                         String?
  current_city                 String?
  date_of_birth                DateTime?              @db.Date
  engagement_type              String?
  international_premium        Decimal?               @db.Decimal(10, 2)
  media_consent                Boolean?               @default(false)
  music_experience_years       Int?
  onboarding_completed         Boolean?               @default(false)
  open_to_international        Boolean?               @default(false)
  performance_experience_years Int?
  phone                        String?
  pincode                      String?
  teaching_experience_years    Int?
  updated_at                   DateTime?              @default(now()) @db.Timestamptz(6)
  profile_picture              String?
  demo                         Boolean?               @default(false)
  tagline                      String?
  teaching_style               String?
  education                    String?
  professional_experience      String?
  youtube_links                String[]               @default([])
  bookings                     bookings[]
  class_packages               class_packages[]
  reviews                      reviews[]
  teacher_availability         teacher_availability[]
  teacher_engagements          teacher_engagements?
  teacher_formats              teacher_formats?
  teacher_instruments          teacher_instruments[]
  teacher_languages            teacher_languages[]
  profiles                     profiles               @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([onboarding_completed])
  @@schema("public")
}

/// Languages taught by teacher
model teacher_languages {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacher_id String   @db.Uuid
  language   String
  created_at DateTime @default(now()) @db.Timestamptz(6)
  teachers   teachers @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([teacher_id])
  @@schema("public")
}

/// Engagement preferences (Teaching/Performance/Both + collaborative projects)
model teacher_engagements {
  id                       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacher_id               String   @unique @db.Uuid
  engagement_type          String
  collaborative_projects   String[]
  collaborative_other      String?
  created_at               DateTime @default(now()) @db.Timestamptz(6)
  updated_at               DateTime @default(now()) @db.Timestamptz(6)
  performance_fee_per_hour Decimal? @db.Decimal(10, 2)
  teachers                 teachers @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

/// Teaching formats and specializations
model teacher_formats {
  id                         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacher_id                 String   @unique @db.Uuid
  class_formats              String[]
  class_formats_other        String?
  exam_training              String[]
  exam_training_other        String?
  additional_formats         String[]
  additional_formats_other   String?
  learner_groups             String[]
  learner_groups_other       String?
  other_contribution         String?
  created_at                 DateTime @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime @default(now()) @db.Timestamptz(6)
  performance_settings       String[] @default([])
  performance_settings_other String?
  teachers                   teachers @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("public")
}

/// Instruments with pricing and modes
model teacher_instruments {
  id                       String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacher_id               String                     @db.Uuid
  instrument               String
  teach_or_perform         String
  base_price               Decimal?                   @db.Decimal(10, 2)
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @default(now()) @db.Timestamptz(6)
  class_mode               class_mode?
  performance_fee_foreign  Decimal?                   @db.Decimal(10, 2)
  performance_fee_inr      Decimal?                   @db.Decimal(10, 2)
  performance_platform_markup_inr Decimal?            @db.Decimal(10, 2)
  teacher_instrument_tiers teacher_instrument_tiers[]
  teachers                 teachers                   @relation(fields: [teacher_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([teacher_id])
  @@schema("public")
}

/// Per-level pricing for teaching instruments
model teacher_instrument_tiers {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teacher_instrument_id String              @db.Uuid
  level                 instrument_level
  mode                  class_mode
  price_inr             Decimal             @db.Decimal(10, 2)
  platform_markup_inr   Decimal?            @db.Decimal(10, 2)
  price_foreign         Decimal?            @db.Decimal(10, 2)
  created_at            DateTime            @default(now()) @db.Timestamptz(6)
  updated_at            DateTime            @default(now()) @db.Timestamptz(6)
  teacher_instruments   teacher_instruments @relation(fields: [teacher_instrument_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([teacher_instrument_id])
  @@schema("public")
}

enum aal_level {
  aal1
  aal2
  aal3

  @@schema("auth")
}

enum code_challenge_method {
  s256
  plain

  @@schema("auth")
}

enum factor_status {
  unverified
  verified

  @@schema("auth")
}

enum factor_type {
  totp
  webauthn
  phone

  @@schema("auth")
}

enum instrument_level {
  beginner
  intermediate
  advanced

  @@schema("public")
}

enum class_mode {
  online
  offline

  @@schema("public")
}

enum oauth_authorization_status {
  pending
  approved
  denied
  expired

  @@schema("auth")
}

enum oauth_client_type {
  public
  confidential

  @@schema("auth")
}

enum oauth_registration_type {
  dynamic
  manual

  @@schema("auth")
}

enum oauth_response_type {
  code

  @@schema("auth")
}

enum one_time_token_type {
  confirmation_token
  reauthentication_token
  recovery_token
  email_change_token_new
  email_change_token_current
  phone_change_token

  @@schema("auth")
}
